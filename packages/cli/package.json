{
  "name": "@nim-ui/cli",
  "version": "0.0.0",
  "description": "CLI foundation for Nim UI project initialization and component scaffolding.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nimjs/nim-ui.git"
  },
  "bugs": {
    "url": "https://github.com/nimjs/nim-ui/issues"
  },
  "homepage": "https://github.com/nimjs/nim-ui#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src/templates",
    "README.md"
  ],
  "bin": {
    "nim-ui": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm --target node20 --clean",
    "clean": "rm -rf dist coverage",
    "dev": "tsup src/index.ts --dts --format esm --target node20 --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nim-ui/registry": "workspace:*",
    "jiti": "^2.7.0"
  }
}
