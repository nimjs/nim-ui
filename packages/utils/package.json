{
  "name": "@nim-ui/utils",
  "version": "0.0.0",
  "description": "Shared utility helpers for Nim UI.",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nimjs/nim-ui.git"
  },
  "bugs": {
    "url": "https://github.com/nimjs/nim-ui/issues"
  },
  "homepage": "https://github.com/nimjs/nim-ui#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --clean",
    "clean": "rm -rf dist coverage",
    "dev": "tsup src/index.ts --dts --format esm,cjs --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  }
}
